{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "melkor-viewer",
  "version": "0.1.0",
  "identifier": "dev.melkor.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8771",
    "beforeDevCommand": "bun serve.js",
    "beforeBuildCommand": "bun stage-dist.js"
  },
  "app": {
    "windows": [
      {
        "title": "Melkor · SparkJS Viewer",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
