 }  // namespace
 
+int32_t getSpzVersion(const uint8_t *data, int32_t size) {
+  if (data == nullptr || size <= 0)
+    return 0;
+  uint8_t headerBytes[sizeof(PackedGaussiansHeader)] = {};
+  z_stream stream = {};
+  stream.next_in = const_cast<Bytef *>(data);
+  stream.avail_in = static_cast<uInt>(size);
+  stream.next_out = headerBytes;
+  stream.avail_out = sizeof(headerBytes);
+  if (inflateInit2(&stream, 16 | MAX_WBITS) != Z_OK)
+    return 0;
+  while (stream.avail_out > 0) {
+    const int32_t result = inflate(&stream, Z_NO_FLUSH);
+    if (result == Z_STREAM_END || result != Z_OK)
+      break;
+  }
+  const size_t produced = sizeof(headerBytes) - stream.avail_out;
+  inflateEnd(&stream);
+  if (produced < sizeof(PackedGaussiansHeader))
+    return 0;
+  PackedGaussiansHeader header;
+  std::memcpy(&header, headerBytes, sizeof(header));
+  return header.magic == PackedGaussiansHeader().magic
+             ? static_cast<int32_t>(header.version)
+             : 0;
+}
