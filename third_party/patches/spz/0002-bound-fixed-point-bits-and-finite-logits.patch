 constexpr uint8_t FlagAntialiased = 0x1;
 
+// Versions 2 and 3 store each coordinate as one signed 24-bit fixed-point
+// integer. At most 23 of those bits can be fractional because one bit carries
+// the sign. Version 1 stores float16 positions and does not consume this field.
+constexpr uint8_t MaxFixedPointFractionalBits = 23;
+
+bool validFractionalBits(uint32_t version, uint8_t fractionalBits) {
+  return version == 1 || fractionalBits <= MaxFixedPointFractionalBits;
+}
+
+float fixedPointEncodeScale(int32_t fractionalBits) {
+  if (fractionalBits < 0 || fractionalBits > MaxFixedPointFractionalBits)
+    return std::numeric_limits<float>::quiet_NaN();
+  return std::ldexp(1.0f, fractionalBits);
+}
+
+float fixedPointDecodeScale(int32_t fractionalBits) {
+  if (fractionalBits < 0 || fractionalBits > MaxFixedPointFractionalBits)
+    return std::numeric_limits<float>::quiet_NaN();
+  return std::ldexp(1.0f, -fractionalBits);
+}
