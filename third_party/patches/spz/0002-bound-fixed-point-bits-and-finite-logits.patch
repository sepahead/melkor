 float sigmoid(float x) { return 1 / (1 + std::exp(-x)); }
 
-float invSigmoid(float x) { return std::log(x / (1.0f - x)); }
+float invSigmoid(float x) {
+  // Packed alpha uses the full uint8 range. Bytes 0 and 255 therefore map to
+  // exact probability endpoints, whose mathematical logits are infinite.
+  // Keep decoded clouds finite using the same epsilon contract as Melkor's
+  // public logit helper; this also makes SPZ round-trips of the default opacity
+  // (1.0 -> byte 255) structurally valid.
+  constexpr float epsilon = 1e-6f;
+  x = std::clamp(x, epsilon, 1.0f - epsilon);
+  return std::log(x / (1.0f - x));
+}
 
